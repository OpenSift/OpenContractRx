# Postgres
POSTGRES_DB=opencontractrx
POSTGRES_USER=opencontractrx
POSTGRES_PASSWORD=opencontractrx
DATABASE_URL=postgresql+psycopg://opencontractrx:opencontractrx@db:5432/opencontractrx

# Redis (worker broker/backing)
REDIS_URL=redis://redis:6379/0

# MinIO (S3-compatible object storage)
