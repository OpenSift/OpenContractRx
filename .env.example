# Postgres
POSTGRES_DB=opencontractrx
POSTGRES_USER=opencontractrx
POSTGRES_PASSWORD=opencontractrx
DATABASE_URL=postgresql+psycopg://opencontractrx:opencontractrx@db:5432/opencontractrx

# Redis (worker broker/backing)
REDIS_URL=redis://redis:6379/0

# MinIO (S3-compatible object storage)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
S3_ENDPOINT=http://minio:9000
S3_BUCKET=opencontractrx
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_REGION=us-east-1

# App
API_HOST=0.0.0.0
API_PORT=8000
WEB_PORT=3000

# Auth (dev-only placeholder)
JWT_SECRET=dev-change-me
JWT_ISSUER=opencontractrx
CREDENTIALS_ENCRYPTION_KEY=

# ChatGPT OAuth (optional)
CHATGPT_OAUTH_CLIENT_ID=
CHATGPT_OAUTH_CLIENT_SECRET=
CHATGPT_OAUTH_AUTH_URL=
CHATGPT_OAUTH_TOKEN_URL=
CHATGPT_OAUTH_REDIRECT_URI=
CHATGPT_OAUTH_SCOPES=openid profile

# Codex OAuth (optional)
CODEX_OAUTH_CLIENT_ID=
CODEX_OAUTH_CLIENT_SECRET=
CODEX_OAUTH_AUTH_URL=
CODEX_OAUTH_TOKEN_URL=
CODEX_OAUTH_REDIRECT_URI=
CODEX_OAUTH_SCOPES=openid profile

# Claude OAuth (optional)
